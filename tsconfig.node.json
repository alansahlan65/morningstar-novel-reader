{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest/globals"],
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "src/**/*.test.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts"
  ]
}
